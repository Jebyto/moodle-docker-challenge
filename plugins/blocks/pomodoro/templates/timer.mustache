{{!
    @template block_pomodoro/timer

    Initial block interface for the Pomodoro timer.

    Context variables required for this template:
    * rootid
    * title
    * subtitle
    * summary
    * focus
    * shortbreak
    * longbreak
    * currentcycle
    * cyclesbeforelongbreak
    * savesettings
    * startpomodoro
    * openfullscreen
    * fullscreenurl
}}
<div id="{{rootid}}" class="block-pomodoro" data-pomodoro-block-root>
    <div class="mb-3">
        <strong class="d-block">{{title}}</strong>
        <span class="d-block small text-muted">{{subtitle}}</span>
    </div>

    <div class="border rounded p-2 mb-3" aria-live="polite">
        <span class="d-block small text-muted">{{summary}}</span>
        <strong class="d-block" data-pomodoro-block-mode>{{focus}}</strong>
        <strong class="h4 d-block mb-1" data-pomodoro-block-time>25:00</strong>
        <span class="badge badge-light border">{{currentcycle}} <strong data-pomodoro-block-cycle>1</strong></span>
    </div>

    <div class="form-row">
        <label class="form-group col-12 mb-2">
            <span class="d-flex justify-content-between small font-weight-bold">
                <span>{{focus}}</span>
                <span class="text-muted" data-pomodoro-range-output>25min</span>
            </span>
            <input class="custom-range" type="range" min="30" max="1800" step="30" value="1500" data-pomodoro-setting-field="focusDurationSeconds">
        </label>
        <label class="form-group col-12 mb-2">
            <span class="d-flex justify-content-between small font-weight-bold">
                <span>{{shortbreak}}</span>
                <span class="text-muted" data-pomodoro-range-output>5min</span>
            </span>
            <input class="custom-range" type="range" min="30" max="1800" step="30" value="300" data-pomodoro-setting-field="shortBreakDurationSeconds">
        </label>
        <label class="form-group col-12 mb-2">
            <span class="d-flex justify-content-between small font-weight-bold">
                <span>{{longbreak}}</span>
                <span class="text-muted" data-pomodoro-range-output>15min</span>
            </span>
            <input class="custom-range" type="range" min="30" max="1800" step="30" value="900" data-pomodoro-setting-field="longBreakDurationSeconds">
        </label>
        <label class="form-group col-12 mb-2">
            <span class="d-flex justify-content-between small font-weight-bold">
                <span>{{cyclesbeforelongbreak}}</span>
                <span class="text-muted" data-pomodoro-range-output>4</span>
            </span>
            <input class="custom-range" type="range" min="1" max="10" step="1" value="4" data-pomodoro-setting-field="cyclesBeforeLongBreak">
        </label>
    </div>

    <div class="d-flex flex-wrap align-items-center">
        <button type="button" class="btn btn-primary mr-2 mb-2" data-pomodoro-block-start>
            {{startpomodoro}}
        </button>
        <button type="button" class="btn btn-secondary mr-2 mb-2" data-pomodoro-block-save>
            {{savesettings}}
        </button>
        <a class="btn btn-link mb-2" href="{{fullscreenurl}}" data-pomodoro-block-fullscreen>
            {{openfullscreen}}
        </a>
    </div>
</div>
